{
  "name": "parklanemethodist",
  "compatibility_date": "2026-05-09",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./src/index.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/functions/*", "/submit", "/test"]
  },
  "send_email": [
    {
      "name": "EMAIL",
      "allowed_sender_addresses": ["no-reply@parklanemethodist.org.uk"]
    }
  ]
}
